# ==============================================================================
# BatchQC - Target Git Ignore Configuration
# ==============================================================================

# --- Python Environment & Runtime Artifacts ---
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.vscode/
.idea/

# --- Local Databases (User Configurations & Curation Registries) ---
database/*.db
!database/.gitkeep

# --- Runtime Data Directories (Audio Assets & Diagnostic Visuals) ---
input/*
!input/.gitkeep

output/corrupted/*
!output/corrupted/.gitkeep

output/good-quality/*
!output/good-quality/.gitkeep

output/good-quality-formatted/*
!output/good-quality-formatted/.gitkeep

output/low-quality/*
!output/low-quality/.gitkeep

output/trash/*
!output/trash/.gitkeep

output/spectrograms/*
!output/spectrograms/.gitkeep